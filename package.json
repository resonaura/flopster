{
  "name": "flopster",
  "version": "1.22",
  "description": "Floppy drive instrument plugin by Shiru & Resonaura",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "node scripts/run.js build",
    "build:release": "node scripts/run.js build --release",
    "build:debug": "node scripts/run.js build --debug",
    "rebuild": "node scripts/run.js build --rebuild",
    "rebuild:debug": "node scripts/run.js build --debug --rebuild",
    "install:plugin": "node scripts/run.js install",
    "reinstall": "node scripts/run.js install --rebuild",
    "dist": "node scripts/dist.js --all",
    "dist:mac": "node scripts/dist.js --mac",
    "dist:win": "node scripts/dist.js --win",
    "set-version": "node -e \"const v=process.argv[1];if(!v||!/^\\d+\\.\\d+/.test(v)){console.error('Usage: npm run set-version <x.y.z>');process.exit(1);}const fs=require('fs');fs.writeFileSync('src/version.h','#pragma once\\n// Edit this value to update the plugin version string, then run install.sh.\\n// npm run set-version <x.y.z> also updates this file automatically.\\n#define FLOPSTER_VERSION \\\"'+v+'\\\"\\n');const pkg=JSON.parse(fs.readFileSync('package.json','utf8'));pkg.version=v;fs.writeFileSync('package.json',JSON.stringify(pkg,null,2)+'\\n');console.log('Version set to '+v);\" --",
    "clean": "node -e \"require('fs').rmSync('build',{recursive:true,force:true}); require('fs').rmSync('build-debug',{recursive:true,force:true});\"",
    "mac:build": "bash build.sh",
    "mac:build:release": "bash build.sh --release",
    "mac:build:debug": "bash build.sh --debug",
    "mac:rebuild": "bash build.sh --rebuild",
    "mac:rebuild:debug": "bash build.sh --debug --rebuild",
    "mac:install": "bash install.sh",
    "mac:reinstall": "bash install.sh --rebuild",
    "mac:dist": "node scripts/dist.js --mac",
    "win:build": "build.bat",
    "win:build:release": "build.bat --release",
    "win:build:debug": "build.bat --debug",
    "win:rebuild": "build.bat --rebuild",
    "win:install": "install.bat",
    "win:reinstall": "install.bat --rebuild",
    "win:dist": "node scripts/dist.js --win"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/resonaura/flopster"
  },
  "author": "Shiru & Resonaura",
  "license": "WTFPL"
}
