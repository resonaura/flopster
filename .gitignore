# =============================================================================
#  Flopster .gitignore
# =============================================================================

# ── Dist output (compiled zips, staging — generated, not committed) ──────────
dist/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/

# ── Build directories ─────────────────────────────────────────────────────────
build/
build-debug/
build-release/
build-win/
build-win-debug/
plugin/build/
plugin/build_release/
plugin/build_debug/
plugin/build-win/

# ── CMake artifacts ───────────────────────────────────────────────────────────
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
*.ninja
.ninja_deps
.ninja_log
JUCE_build/

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*

# ── Windows system files ──────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Compiled output ───────────────────────────────────────────────────────────
*.o
*.obj
*.a
*.lib
*.pdb
*.ilk
*.exp

# ── JUCE framework (fetched automatically by build scripts) ──────────────────
JUCE/

# ── IDE / editor project files ───────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.suo
*.user
*.userosscache
*.sln.docstates
*.ncb
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb

# ── Xcode ─────────────────────────────────────────────────────────────────────
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.moved-aside
DerivedData/

# ── Visual Studio ─────────────────────────────────────────────────────────────
.vs/
x64/
x86/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
[Rr]elease[Pp]ublic/
*.aps

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Certificates / signing ────────────────────────────────────────────────────
*.p12
*.cer
*.provisionprofile
compile_commands.json

.cache
.wix
/build-*
.claude
